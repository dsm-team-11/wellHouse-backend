# 이 파일을 복사해서 backend/.env 를 만들고 실제 값을 채우세요.
#   cp .env.example .env
# .env 는 .gitignore 에 있어 커밋되지 않습니다. 앱 실행 시 자동 로드됩니다(spring-dotenv).
# ⚠️ 이 예시 파일은 커밋되므로 실제 키/비밀번호를 절대 여기에 넣지 마세요. (실제 값은 .env 에만)

# 비밀번호 재설정 메일 발송 (Gmail SMTP)
WELLHOUSE_MAIL_ENABLED=true
# 보내는 Gmail 주소
MAIL_USERNAME=your-account@gmail.com
# Gmail "앱 비밀번호" 16자리 (일반 로그인 비밀번호 아님, 2단계 인증 후 발급)
MAIL_PASSWORD=xxxxxxxxxxxxxxxx
# 받는 사람에게 표시될 발신자 주소 — Gmail 은 보통 MAIL_USERNAME 으로 강제되므로 동일하게 두는 걸 권장
WELLHOUSE_MAIL_FROM=your-account@gmail.com

# (선택) 다른 SMTP 서버를 쓸 때만 변경
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587

# 기상청 날씨 연동 (공공데이터포털 data.go.kr → "기상청_단기예보 조회서비스")
# 발급받은 "일반 인증키(Decoding)" 를 그대로 넣으세요. 비우면 강수 0 으로 안전 동작.
KMA_SERVICE_KEY=
