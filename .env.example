# ⚠️ 이 파일(.env.example)은 GitHub 에 커밋됩니다 — 실제 키/비밀번호를 절대 넣지 마세요!
# 실제 값은 반드시 backend/.env 에만 넣으세요 (.env 는 .gitignore 되어 커밋 안 됨).
#   설정 방법:  cp .env.example .env  후 .env 를 편집
# 앱 실행 시 .env 가 자동 로드됩니다(spring-dotenv).

# 비밀번호 재설정 메일 발송 (Gmail SMTP)
WELLHOUSE_MAIL_ENABLED=true
MAIL_USERNAME=your-account@gmail.com
# Gmail "앱 비밀번호" 16자리 (일반 로그인 비밀번호 아님, 2단계 인증 후 발급)
MAIL_PASSWORD=xxxxxxxxxxxxxxxx
WELLHOUSE_MAIL_FROM=your-account@gmail.com

# (선택) 다른 SMTP 서버를 쓸 때만 변경
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587

# 기상청 날씨 (공공데이터포털 "일반 인증키 Decoding"). 비우면 강수 0 으로 안전 동작.
KMA_SERVICE_KEY=

# AI(GPT) — OpenAI API 키. 비우면 AI 기능은 규칙 기반 기본 문구로 폴백.
OPENAI_API_KEY=
# (선택) 모델. 기본 gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
